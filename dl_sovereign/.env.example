# ── Required ──────────────────────────────────────────
ALCHEMY_WSS_URL=wss://eth-mainnet.g.alchemy.com/v2/YOUR_KEY_HERE
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HEX
WALLET_ADDRESS=0xYOUR_WALLET_ADDRESS

# ── Optional ───────────────────────────────────────────
# Minimum profit in ETH before executing (default 0.003)
MIN_PROFIT_ETH=0.003
# Max trade size in ETH (default 3.0)
MAX_TRADE_ETH=3.0
