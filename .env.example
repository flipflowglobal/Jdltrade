# JDL Trade Coding Agent — Environment Configuration
# Copy to .env and fill in your values:
#   cp .env.example .env

# ── Required ─────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Agent Tuning ─────────────────────────────────────
# Max output tokens (Claude Opus 4.6 supports up to 128k)
AGENT_MAX_TOKENS=128000

# Effort level: low | medium | high | max
# 'max' = deepest reasoning, most thorough — best for complex crypto systems
AGENT_EFFORT=max

# ── Paths (optional, defaults shown) ─────────────────
# AGENT_MEMORY_DIR=~/.jdltrade/memory
# AGENT_SESSION_DIR=~/.jdltrade/sessions
# AGENT_WORKSPACE=~/.jdltrade/workspace

# ── Crypto API Keys (optional) ───────────────────────
# CoinGecko (free tier works without a key, key gives higher rate limits)
COINGECKO_API_KEY=

# Binance (for live trading features)
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
