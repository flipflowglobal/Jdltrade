# ============================================================
# NEXUS-ARB v2.0 — Environment Configuration
# Copy to .env and fill in your values. NEVER commit .env!
# ============================================================

# ─── RPC Endpoints (Arbitrum) ───────────────────────────────
# Primary WebSocket (fastest, used for mempool monitoring)
ARB_WS_PRIMARY=wss://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
# Secondary WebSocket (failover)
ARB_WS_SECONDARY=wss://arbitrum-one.blastapi.io/YOUR_KEY
# HTTP endpoints (used for multicall, batch queries)
ARB_HTTP_1=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
ARB_HTTP_2=https://arbitrum-one.blastapi.io/YOUR_KEY
ARB_HTTP_3=https://rpc.ankr.com/arbitrum/YOUR_KEY
ARB_HTTP_4=https://1rpc.io/arb

# ─── Wallet ──────────────────────────────────────────────────
# Private key for signing transactions (use hardware wallet in prod)
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE
# Optional: use AWS KMS / HashiCorp Vault instead
USE_KMS=false
KMS_KEY_ID=
VAULT_ADDR=
VAULT_TOKEN=

# ─── Deployed Contract ───────────────────────────────────────
NEXUS_RECEIVER_ADDRESS=0xYOUR_DEPLOYED_CONTRACT

# ─── Telegram Alerts ────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Monitoring ─────────────────────────────────────────────
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# ─── Environment ────────────────────────────────────────────
ENVIRONMENT=production
LOG_LEVEL=INFO
DRY_RUN=false
